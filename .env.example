# Vercel defaults for the FreeGPT4 serverless deployment
DEFAULT_MODEL=gpt-4o
DEFAULT_PROVIDER=PollinationsAI
FREEGPT4_ENABLE_GUI=false
FREEGPT4_ENABLE_HISTORY=false
FREEGPT4_REMOVE_SOURCES=true

# Optional: set this to protect the endpoint, then set the same value as FREEGPT4_TOKEN in the main backend.
FREEGPT4_API_KEY=